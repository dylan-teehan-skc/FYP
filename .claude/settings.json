{
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)"
    ],
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Bash(cd *)",
      "Bash(ls *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(.venv/bin/python3 -m pytest *)",
      "Bash(.venv/bin/python3 -m ruff *)",
      "Bash(.venv/bin/python3 main.py *)",
      "Bash(.venv/bin/python3 -m mypy *)",
      "Bash(PYTHONPATH=* .venv/bin/python3 *)",
      "Bash(uv pip install *)",
      "Bash(VIRTUAL_ENV=* uv pip install *)",
      "Bash(curl -s http://localhost*)",
      "Bash(stat *)",
      "Bash(cat *)",
      "Bash(tail *)",
      "Bash(head *)",
      "Bash(wc *)",
      "Bash(mkdir *)"
    ]
  }
}
